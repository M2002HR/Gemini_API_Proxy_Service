# -------- Global --------
APP_CONFIG_FILE=config/config.yml

# -------- App --------
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO
APP_REQUEST_TIMEOUT_SEC=120

# -------- Proxy behavior --------
PROXY_MODE=cloudflare_worker
PROXY_TRUST_ENV_PROXY=true
PROXY_RETRY_ON_429=true
PROXY_MAX_RETRIES_PER_KEY=2
PROXY_COOLOFF_SEC=30
PROXY_MIN_INTERVAL_SEC=0

# -------- Gemini --------
GEMINI_BASE_URL=https://generativelanguage.googleapis.com
GEMINI_API_VERSION=v1beta
GEMINI_DEFAULT_MODEL=gemini-2.5-flash
# Used only for gemini_direct mode:
GEMINI_API_KEYS=key1,key2,key3
# JSON object, optional:
GEMINI_DEFAULT_REQUEST_JSON={"generationConfig":{"temperature":0.3}}

# -------- Cloudflare Worker --------
CLOUDFLARE_WORKER_BASE_URLS=https://your-worker-subdomain.workers.dev
CLOUDFLARE_WORKER_ROUTE_PREFIX=/gemini
CLOUDFLARE_AUTH_TOKEN=
CLOUDFLARE_AUTH_HEADER_NAME=x-worker-auth
CLOUDFLARE_ACCESS_CLIENT_ID=
CLOUDFLARE_ACCESS_CLIENT_SECRET=
CLOUDFLARE_PASS_TRACE_HEADERS=true
